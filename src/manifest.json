{
  "manifest_version": 3,
  "name": "PysznePay",
  "version": "1.0.0",
  "description": "Rozliczanie zamówień z Pyszne.pl",
  "permissions": ["scripting", "tabs"],
  "host_permissions": ["https://www.pyszne.pl/*"],
  "background": {
    "service_worker": "background/index.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
